{
  "name": "@june/comma-editor-kit",
  "version": "0.3.0",
  "private": true,
  "description": "Local-first, embeddable Markdown review and revision workbench.",
  "type": "module",
  "main": "./dist/comma-editor.js",
  "module": "./dist/comma-editor.js",
  "exports": {
    ".": "./dist/comma-editor.js"
  },
  "files": [
    "dist",
    "chrome-extension",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:chrome": "vite build --mode chrome && node scripts/package-chrome.mjs",
    "test": "node --test tests/*.test.mjs",
    "test:review": "python3 -m unittest discover -s apps/review-studio -p 'test_review_*.py'",
    "validate:chrome": "node scripts/validate-extension.mjs",
    "check": "npm test && npm run test:review && npm run build:chrome && npm run validate:chrome"
  },
  "dependencies": {
    "dompurify": "3.4.12",
    "highlight.js": "11.11.1",
    "katex": "0.16.47",
    "mammoth": "1.12.0",
    "marked": "16.4.2",
    "mermaid": "11.16.0",
    "pdfjs-dist": "6.1.200",
    "sanitize-html": "2.17.6",
    "turndown": "7.2.4",
    "turndown-plugin-gfm": "1.0.2"
  },
  "devDependencies": {
    "vite": "7.3.6"
  },
  "engines": {
    "node": ">=20"
  }
}
